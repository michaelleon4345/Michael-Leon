<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TagoIO HUD Distancia</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&display=swap');

        :root {
            --theme-color: #00f3ff;
            --theme-glow: rgba(0, 243, 255, 0.5);
            --theme-bg: rgba(0, 243, 255, 0.05);
        }

        body {
            font-family: 'Share Tech Mono', monospace;
            margin: 0;
            padding: 0;
            background-color: transparent; /* Importante para dashboards */
            color: var(--theme-color);
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        .hud-container {
            background: #0a0a12;
            background-image: 
                linear-gradient(var(--theme-bg) 1px, transparent 1px),
                linear-gradient(90deg, var(--theme-bg) 1px, transparent 1px);
            background-size: 20px 20px;
            padding: 20px;
            border-radius: 10px;
            border: 2px solid var(--theme-color);
            box-shadow: 0 0 15px var(--theme-glow);
            width: 90%;
            max-width: 350px;
            position: relative;
            text-align: center;
            transition: all 0.4s ease;
        }

        .scanline {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 4px;
            background: var(--theme-color);
            opacity: 0.4;
            box-shadow: 0 0 10px var(--theme-color);
            animation: scan 4s infinite linear;
            pointer-events: none;
        }

        @keyframes scan {
            0% { top: 0%; }
            100% { top: 100%; }
        }

        .header {
            font-size: 0.8em;
            letter-spacing: 2px;
            margin-bottom: 10px;
            border-bottom: 1px solid var(--theme-color);
            opacity: 0.8;
        }

        .value-box {
            display: flex;
            justify-content: center;
            align-items: baseline;
            margin: 10px 0;
        }

        .value {
            font-size: 4em;
            text-shadow: 0 0 10px var(--theme-color);
        }

        .unit {
            font-size: 1.2em;
            margin-left: 5px;
        }

        .bar-container {
            width: 100%;
            height: 12px;
            background: rgba(255,255,255,0.1);
            border: 1px solid var(--theme-color);
            border-radius: 5px;
            margin-bottom: 10px;
        }

        .bar-fill {
            height: 100%;
            width: 0%;
            background: var(--theme-color);
            box-shadow: 0 0 8px var(--theme-color);
            transition: width 0.3s ease;
        }

        .status-msg {
            font-size: 0.75em;
            height: 15px;
            font-weight: bold;
        }

        /* Estados dinámicos */
        .mode-safe {
            --theme-color: #00ffaa;
            --theme-glow: rgba(0, 255, 170, 0.4);
        }
        .mode-warning {
            --theme-color: #ffaa00;
            --theme-glow: rgba(255, 170, 0, 0.4);
        }
        .mode-danger {
            --theme-color: #ff0044;
            --theme-glow: rgba(255, 0, 68, 0.5);
            animation: shake 0.2s infinite;
        }

        @keyframes shake {
            0% { transform: translate(1px, 0); }
            50% { transform: translate(-1px, 0); }
            100% { transform: translate(1px, 0); }
        }
    </style>
</head>
<body>

    <div id="hud" class="hud-container mode-safe">
        <div class="scanline"></div>
        <div class="header">TAGOIO SENSOR DATA</div>
        
        <div class="value-box">
            <div id="distance-value" class="value">---</div>
            <div class="unit">cm</div>
        </div>

        <div class="bar-container">
            <div id="distance-bar" class="bar-fill"></div>
        </div>

        <div id="status-msg" class="status-msg">CONECTANDO...</div>
    </div>

    <script src="https://admin.tago.io/dist/custom-widget.js"></script>
    
    <script>
        // Inicializar comunicación con TagoIO
        window.TagoIO.ready();

        /**
         * Función principal de procesamiento de datos
         */
        function processData(data) {
            if (!data || data.length === 0) return;

            // TagoIO envía un array de objetos. Buscamos la variable de distancia.
            // Si solo tienes una variable en el widget, suele ser data[0]
            const item = data.find(variable => variable.variable === 'distancia' || variable.variable === 'distance') || data[0];
            
            if (item && item.value !== undefined) {
                const valor = parseFloat(item.value);
                updateUI(valor);
            }
        }

        function updateUI(valor) {
            const valElement = document.getElementById('distance-value');
            const barElement = document.getElementById('distance-bar');
            const hud = document.getElementById('hud');
            const msg = document.getElementById('status-msg');

            // Actualizar número
            valElement.innerText = valor.toFixed(1);

            // Actualizar barra (Rango 0-100cm)
            let porcentaje = (valor / 100) * 100;
            porcentaje = Math.min(Math.max(porcentaje, 0), 100);
            barElement.style.width = (100 - porcentaje) + '%';

            // Lógica de estados
            if (valor < 15) {
                hud.className = 'hud-container mode-danger';
                msg.innerText = '¡ALERTA: IMPACTO INMINENTE!';
            } else if (valor < 40) {
                hud.className = 'hud-container mode-warning';
                msg.innerText = 'PRECAUCIÓN: OBJETO PRÓXIMO';
            } else {
                hud.className = 'hud-container mode-safe';
                msg.innerText = 'SISTEMA NOMINAL - DESPEJADO';
            }
        }

        // Listener para datos en tiempo real (TagoIO)
        window.TagoIO.onRealtime((data) => {
            processData(data);
        });

        // Cargar datos iniciales
        window.TagoIO.onStart((widget) => {
            if (widget && widget.display && widget.display.variables) {
                // TagoIO a veces estructura los datos diferente al inicio
                processData(widget.data);
            }
        });
    </script>
</body>
</html>
